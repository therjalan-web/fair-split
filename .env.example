# Copy to .env and set at least one key. NEVER commit .env to git.
# Keys are persistent — you create them ONCE and reuse them forever.
# The app tries providers in this order: Gemini → OpenRouter → Groq.

# Option 1 (RECOMMENDED): Google AI Studio — free, no card, ~1500 req/day, never expires
#   https://aistudio.google.com/apikey  (use a personal Gmail; .ac.in accounts are blocked)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2 (fallback): OpenRouter — free models, 50 req/day without credits
#   https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=your_openrouter_key_here

# Option 3 (text-only fallback): Groq — free, but its vision models were deprecated in 2026
# GROQ_API_KEY=your_groq_key_here

# Optional model overrides
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct:free
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
